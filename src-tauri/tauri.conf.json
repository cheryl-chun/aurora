{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aurora",
  "version": "0.1.3",
  "identifier": "com.cheryl.aurora",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "aurora",
        "width": 1080,
        "height": 720,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZBNDdDMkFCQzI2NUNFQTgKUldTb3ptWENxOEpIYW55NWh4ODVSNm00KzRVWUQyQXpweTlzdnF2UUwra3EvbWpqRTFhZUtjd3MK",
      "endpoints": [
        "https://github.com/cheryl-chun/aurora/releases/latest/download/latest.json"
      ]
    }
  }
}
